generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

enum LogEntryType {
  ARRIVAGE
  VENTE
  RETOUR
  AJUSTEMENT
  NOTE
}

enum DailyLogStatus {
  OPEN
  CLOSED
}

model User {
  id           Int      @id @default(autoincrement())
  shopName     String
  ownerName    String
  email        String   @unique
  passwordHash String
  category     String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  products  Product[]
  clients   Client[]
  dailyLogs DailyLog[]
  logEntries LogEntry[]
}

model Product {
  id                Int      @id @default(autoincrement())
  vendorId          Int
  vendor            User     @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  name              String
  category          String
  description       String?  @db.Text
  price             Decimal  @db.Decimal(12, 2)
  quantity          Decimal  @default(0) @db.Decimal(14, 3)
  unit              String
  photoPath         String?
  isAvailable       Boolean  @default(true)
  lowStockThreshold Decimal  @default(0) @db.Decimal(14, 3)

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  logEntries LogEntry[]

  @@index([vendorId, category])
  @@index([vendorId, name])
}

model Client {
  id        Int      @id @default(autoincrement())
  vendorId  Int
  vendor    User     @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  name      String
  phone     String
  email     String?
  address   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  logEntries LogEntry[]

  @@index([vendorId, name])
  @@unique([vendorId, phone])
}

model DailyLog {
  id        Int            @id @default(autoincrement())
  vendorId  Int
  vendor    User           @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  /// Date Dakar au format YYYY-MM-DD (évite les pièges de fuseau horaire)
  dateKey   String         @db.VarChar(10)
  status    DailyLogStatus @default(OPEN)
  openedAt  DateTime       @default(now())
  closedAt  DateTime?

  openingStockValue Decimal @default(0) @db.Decimal(14, 2)
  closingStockValue Decimal @default(0) @db.Decimal(14, 2)

  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  entries   LogEntry[]

  @@unique([vendorId, dateKey])
  @@index([vendorId, status])
}

model LogEntry {
  id           Int          @id @default(autoincrement())
  vendorId     Int
  vendor       User         @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  dailyLogId   Int
  dailyLog     DailyLog     @relation(fields: [dailyLogId], references: [id], onDelete: Cascade)

  type         LogEntryType

  productId    Int?
  product      Product?     @relation(fields: [productId], references: [id], onDelete: SetNull)

  clientId     Int?
  client       Client?      @relation(fields: [clientId], references: [id], onDelete: SetNull)

  clientName   String?
  quantity     Decimal?     @db.Decimal(14, 3)
  unitPrice    Decimal?     @db.Decimal(12, 2)
  total        Decimal?     @db.Decimal(14, 2)
  invoiceNumber String?     @db.VarChar(25)
  note         String?      @db.Text

  timestamp    DateTime     @default(now())
  createdAt    DateTime     @default(now())

  @@index([vendorId, timestamp])
  @@index([dailyLogId, timestamp])
  @@index([vendorId, invoiceNumber])
  @@unique([vendorId, invoiceNumber])
}
